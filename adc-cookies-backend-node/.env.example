# Copy this file to ".env" and fill in your own values:  cp .env.example .env

# --- Server ---
PORT=8080

# --- JWT ---
# Use a long, random secret (min 32 chars for HS256). Do NOT commit your real one.
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRATION=86400000

# --- PostgreSQL ---
# Local dev uses Unix-socket "peer" auth (no password) as the current OS user.
# Create the database first with:  npm run db:create
PGHOST=/var/run/postgresql
PGDATABASE=adccookies
PGUSER=your_postgres_user

# For a remote / password-protected database, set DATABASE_URL instead — it takes
# precedence over the PG* vars above. Leave empty to use the PG* vars.
# DATABASE_URL=postgresql://user:password@host:5432/adccookies
DATABASE_URL=
