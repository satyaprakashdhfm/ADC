# Copy this file to ".env" and fill in your own values:  cp .env.example .env

# --- Server ---
PORT=8080
# Comma-separated list of allowed browser origins (your frontend). Leave empty to allow all
# (fine for local dev). Set this in production to lock the API to your real domain(s).
# e.g. ALLOWED_ORIGINS=https://adccookies.com,https://www.adccookies.com,https://adc-frontend.vercel.app
ALLOWED_ORIGINS=

# --- JWT ---
# Use a long, random secret (min 32 chars for HS256). Do NOT commit your real one.
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRATION=86400000

# --- PostgreSQL ---
# Local dev uses Unix-socket "peer" auth (no password) as the current OS user.
# Create the database first with:  npm run db:create
PGHOST=/var/run/postgresql
PGDATABASE=adccookies
PGUSER=your_postgres_user

# For a remote / password-protected database, set DATABASE_URL instead — it takes
# precedence over the PG* vars above. Leave empty to use the PG* vars.
# DATABASE_URL=postgresql://user:password@host:5432/adccookies
DATABASE_URL=

# --- Supabase (server-side: phone-OTP user creation + session minting) ---
SUPABASE_URL=https://<project-ref>.supabase.co
ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_secret

# --- Message Central (VerifyNow phone OTP) ---
# Option A (simplest): paste the long-lived dashboard authToken.
AUTH_KEY=your_message_central_auth_token
CUSTOMER_ID=C-XXXXXXXXXXXXXXX
# Option B (generate on demand instead of AUTH_KEY): CUSTOMER_ID + MC_PASSWORD
# MC_PASSWORD=your_message_central_password
# Optional overrides:
# MC_BASE_URL=https://cpaas.messagecentral.com
# MC_COUNTRY=91
